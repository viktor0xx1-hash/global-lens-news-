{
  "entities": {
    "Article": {
      "title": "Article",
      "description": "A news article on Global Lens.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The headline of the article." },
        "summary": { "type": "string", "description": "A brief summary for the homepage." },
        "content": { "type": "string", "description": "The full article content in Markdown." },
        "author": { "type": "string", "description": "The name of the author." },
        "category": { "type": "string", "description": "The news category (e.g., Geopolitics, Economy)." },
        "imageUrl": { "type": "string", "description": "The main image URL." },
        "imageUrls": { "type": "array", "items": { "type": "string" }, "description": "Array of image URLs for multi-image articles." },
        "videoUrl": { "type": "string", "description": "Optional YouTube or direct video URL." },
        "videoUrls": { "type": "array", "items": { "type": "string" }, "description": "Array of video URLs for multi-video articles." },
        "publishedAt": { "type": "string", "format": "date-time", "description": "When the article was published." },
        "isBreaking": { "type": "boolean", "description": "Whether this is a breaking news story." },
        "language": { "type": "string", "description": "The language code (e.g., en, fa, zh, ru)." }
      },
      "required": ["title", "content", "publishedAt", "language"]
    },
    "LiveUpdate": {
      "title": "Live Update",
      "description": "A short, real-time update for the live feed.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The headline of the update." },
        "summary": { "type": "string", "description": "A brief summary of the update." },
        "content": { "type": "string", "description": "The text of the update." },
        "imageUrl": { "type": "string", "description": "Optional image URL." },
        "imageUrls": { "type": "array", "items": { "type": "string" }, "description": "Array of image URLs." },
        "videoUrl": { "type": "string", "description": "Optional video file URL." },
        "videoUrls": { "type": "array", "items": { "type": "string" }, "description": "Array of video URLs." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the update occurred." },
        "isBreaking": { "type": "boolean", "description": "Whether this is a major breaking update." },
        "language": { "type": "string", "description": "The language code (e.g., en, fa, zh, ru)." }
      },
      "required": ["content", "timestamp", "language"]
    }
  },
  "firestore": {
    "/articles/{articleId}": {
      "schema": "Article",
      "description": "Collection of news articles."
    },
    "/live-updates/{updateId}": {
      "schema": "LiveUpdate",
      "description": "Collection of real-time geopolitical updates."
    }
  }
}
