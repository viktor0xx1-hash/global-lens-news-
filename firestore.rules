rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: articles
    // Fields:
    //   - title: string (required)
    //   - summary: string (optional)
    //   - content: string (required)
    //   - author: string (optional)
    //   - category: string (optional)
    //   - imageUrls: list (optional)
    //   - videoUrls: list (optional)
    //   - publishedAt: timestamp (required)
    //   - isBreaking: bool (optional)
    //
    // Collection: live-updates
    // Fields:
    //   - title: string (optional)
    //   - summary: string (optional)
    //   - content: string (required)
    //   - imageUrls: list (optional)
    //   - videoUrls: list (optional)
    //   - timestamp: timestamp (required)
    //   - isBreaking: bool (optional)
    //
    // Collection: users
    // Fields:
    //   - role: string (optional)
    //   - email: string (optional)
    //   - bookmarks: list (optional)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return request.auth != null && 
             (request.auth.token.email.matches("(?i)viktor0xx1@gmail\\.com") ||
              request.auth.uid == "Dt2QUfA9nCMCTb0NNGg1Ngkf86E3");
    }

    // Rules
    match /test/{docId} {
      allow read, write: if true;
    }

    match /articles/{articleId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /live-updates/{updateId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow update: if isAuthenticated() && request.auth.uid == userId && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['bookmarks']);
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAdmin();
    }
  }
}
