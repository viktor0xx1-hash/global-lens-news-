rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: articles
    // Fields:
    //   - title: string (required)
    //   - summary: string (optional)
    //   - content: string (required)
    //   - author: string (optional)
    //   - category: string (optional)
    //   - imageUrls: list (optional)
    //   - videoUrls: list (optional)
    //   - publishedAt: timestamp (required)
    //   - isBreaking: bool (optional)
    //
    // Collection: live-updates
    // Fields:
    //   - title: string (optional)
    //   - summary: string (optional)
    //   - content: string (required)
    //   - imageUrls: list (optional)
    //   - videoUrls: list (optional)
    //   - timestamp: timestamp (required)
    //   - isBreaking: bool (optional)
    //
    // Collection: users
    // Fields:
    //   - role: string (optional)
    //   - email: string (optional)
    //   - bookmarks: list (optional)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      // Check for explicit email first as it doesn't require a document lookup
      let isExplicitAdmin = isAuthenticated() && 
                            request.auth.token.email.lower() == "viktor0xx1@gmail.com" && 
                            request.auth.token.email_verified == true;
      
      // Then check for role in users collection if document exists
      let hasAdminRole = isAuthenticated() && 
                         exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
                         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
                         
      return isExplicitAdmin || hasAdminRole;
    }

    function isValidArticle(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 500 &&
             data.content is string && data.content.size() > 0 && data.content.size() < 100000 &&
             data.publishedAt is timestamp &&
             (!('imageUrls' in data) || data.imageUrls is list) &&
             (!('videoUrls' in data) || data.videoUrls is list) &&
             (!('isBreaking' in data) || data.isBreaking is bool) &&
             (!('author' in data) || data.author is string) &&
             (!('category' in data) || data.category is string) &&
             (!('summary' in data) || data.summary is string);
    }

    function isValidLiveUpdate(data) {
      return data.content is string && data.content.size() > 0 && data.content.size() < 5000 &&
             data.timestamp is timestamp &&
             (!('title' in data) || data.title is string) &&
             (!('summary' in data) || data.summary is string) &&
             (!('imageUrls' in data) || data.imageUrls is list) &&
             (!('videoUrls' in data) || data.videoUrls is list) &&
             (!('isBreaking' in data) || data.isBreaking is bool);
    }

    // Rules
    match /articles/{articleId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidArticle(request.resource.data);
      allow delete: if isAdmin();
    }

    match /live-updates/{updateId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidLiveUpdate(request.resource.data);
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow update: if isAuthenticated() && request.auth.uid == userId && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['bookmarks']);
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAdmin();
    }
  }
}
